# =============================================================================
# DATABASE
# =============================================================================
# Options: postgres | turso
#   postgres → set POSTGRES_DATABASE_URL
#   turso    → set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN
DB_PROVIDER=

# postgres://[user]:[password]@[host]:[port]/[database]
POSTGRES_DATABASE_URL=postgres://postgres:admin@localhost:5432/b2b_delivery

# Turso (libSQL) — only needed when DB_PROVIDER=turso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# =============================================================================
# AUTH  (Better Auth)
# =============================================================================
BETTER_AUTH_DEV_URL=http://localhost:3000
BETTER_AUTH_PRD_URL=

# Minimum 32 characters — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# =============================================================================
# STORAGE  (avatars, delivery proof photos, pickup-location photos)
# =============================================================================
# Options: local | r2
# Defaults to "local" when unset — no extra setup needed for development.
STORAGE_PROVIDER=local

# --- Local (STORAGE_PROVIDER=local) -----------------------------------------
# Written to LOCAL_UPLOADS_DIR, served via app/uploads/[...path]/route.ts.
# Mount as a Docker volume so files survive redeploys.
# Defaults to ./uploads if unset.
LOCAL_UPLOADS_DIR=./.uploads

# --- Cloudflare R2 (STORAGE_PROVIDER=r2) ------------------------------------
# Account ID — Cloudflare Dashboard → right sidebar
R2_ACCOUNT_ID=

# API token — R2 › Manage API tokens › Create token
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name
R2_BUCKET_NAME=delivery-uploads

# Public URL — r2.dev subdomain or custom domain (bucket Settings › Public Access)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# =============================================================================
# MAIL
# =============================================================================
GMAIL_USER=
GMAIL_APP_PASSWORD=

# =============================================================================
# TUNNEL
# =============================================================================
# Cloudflare Tunnel token — exposes local server to the internet
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# APP
# =============================================================================
# Options: development | production
NEXT_PUBLIC_ENV=development
