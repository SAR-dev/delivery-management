# PostgreSQL connection string: postgres://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgres://postgres:admin@localhost:5432/b2b_delivery

# Base URL of the app (used by Better Auth for redirects and callbacks)
BETTER_AUTH_DEV_URL=http://localhost:3000
BETTER_AUTH_PRD_URL=

# Secret key used by Better Auth to sign tokens and sessions (min 32 chars)
BETTER_AUTH_SECRET='generate a random 32+ char string'

# --- Image uploads (avatars, delivery proof photos, pickup-location photos) -
# Controls which storage backend is used. Options: "local" | "r2"
# Defaults to "local" if unset — safe for development with no extra setup.
STORAGE_PROVIDER=local

# --- Local storage (used when STORAGE_PROVIDER=local) -------------------
# Files are written to UPLOADS_DIR and served via app/uploads/[...path]/route.ts.
# Mount UPLOADS_DIR as a Docker volume so files survive redeploys.
# Defaults to ./uploads inside the project root if unset.
UPLOADS_DIR=./.uploads

# --- Cloudflare R2 storage (used when STORAGE_PROVIDER=r2) --------------
# Files are uploaded to R2 and served directly from R2's public URL.
# See lib/storage/r2.ts for full setup instructions.

# Cloudflare account ID — Dashboard → right sidebar
R2_ACCOUNT_ID=

# R2 API token credentials — R2 > Manage API tokens > Create token
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Name of the R2 bucket
R2_BUCKET_NAME=delivery-uploads

# Public base URL — r2.dev subdomain (enable in bucket Settings > Public Access)
# or your own custom domain
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Token for Cloudflare Tunnel — exposes your local server to the internet
CLOUDFLARE_TUNNEL_TOKEN=

# Environment (development, production)
NEXT_PUBLIC_ENV=development
