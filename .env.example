# PostgreSQL connection string: postgres://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgres://postgres:admin@localhost:5432/b2b_delivery

# Base URL of the app (used by Better Auth for redirects and callbacks)
BETTER_AUTH_DEV_URL=http://localhost:3000
BETTER_AUTH_PRD_URL=

# Secret key used by Better Auth to sign tokens and sessions (min 32 chars)
BETTER_AUTH_SECRET='generate a random 32+ char string'

# Supabase project URL (Project Settings -> API -> Project URL)
# Used server-side only, to store and serve uploaded images (avatars,
# delivery proof photos, pickup-location photos) via Supabase Storage.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (Project Settings -> API -> service_role secret)
# NEVER expose this to the browser — it bypasses Row Level Security and is
# only ever read on the server inside app/api/uploads/route.ts.
SUPABASE_SERVICE_ROLE_KEY=

# Token for Cloudflare Tunnel — exposes your local server to the internet
CLOUDFLARE_TUNNEL_TOKEN=
