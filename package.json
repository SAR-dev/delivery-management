    "db:push": "drizzle-kit push",
    "db:seed": "tsx lib/db/seed.ts",
    "db:seed:min": "tsx lib/db/seed.ts --min",
    "repomix": "repomix",
    "check": "pnpm typecheck && pnpm lint:check && pnpm format:check && pnpm repomix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@base-ui/react": "^1.5.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@vercel/analytics": "1.6.1",
    "better-auth": "^1.6.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compressorjs": "^1.3.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^9.0.1",
    "pg": "8.21.0",
    "react": "^19",
    "react-dom": "^19",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "postcss": "8.5.10",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "repomix": "^1.15.0",
    "rimraf": "^6.1.3",
    "shadcn": "^4.8.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
